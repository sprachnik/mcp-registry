{
  "name": "mcp-registry",
  "version": "1.0.0",
  "description": "Searchable registry of Model Context Protocol (MCP) servers",
  "main": "index.html",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "scrape": "node scripts/scrape-registry.js",
    "validate": "node scripts/validate-servers.js",
    "scrape:dev": "SCRAPER_MAX_SERVERS=100 SCRAPER_BATCH_SIZE=50 SCRAPER_DELAY_MS=50 node scripts/scrape-registry.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sprachnik/mcp-registry.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "servers",
    "registry",
    "search"
  ],
  "author": "James Stalley-Moores",
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
